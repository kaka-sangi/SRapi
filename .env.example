# SRapi local development environment.
# Copy to .env for local overrides. Values here are placeholders only.
#
# ⚠️  PRODUCTION: do NOT ship these values. Before any real deployment you MUST:
#   - SERVER_MODE=release            (versioned migrations, not Ent auto-migrate)
#   - BOOTSTRAP_ADMIN_PASSWORD=...   (a strong, unique password — NOT password123)
#   - JWT_SECRET / SRAPI_MASTER_KEY / API_KEY_PEPPER / TOTP_ENCRYPTION_KEY =
#       fresh 32+ byte random secrets (the *_change_me defaults are dev-only)
#   - DATABASE_PASSWORD=...          (a real DB password)
# deploy/docker-compose.yml defaults SERVER_MODE to release and REQUIRES
# BOOTSTRAP_ADMIN_PASSWORD, so a bare `docker compose up` can't run insecurely.

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=local
SERVER_SHUTDOWN_TIMEOUT_SECONDS=45
SERVER_MAX_REQUEST_BODY_SIZE=268435456
SRAPI_VERSION=0.1.0
STORAGE_BACKEND=postgres
GOMAXPROCS=2

LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE_NAME=srapi
LOG_ENV=local

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=srapi
DATABASE_PASSWORD=srapi_dev_password_change_me
DATABASE_DBNAME=srapi
DATABASE_SSLMODE=disable
# Connection-pool tuning. Size MAX_OPEN_CONNS so (replicas * MAX_OPEN_CONNS)
# stays under Postgres max_connections. 0 = driver default (unbounded open).
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME_SECONDS=1800

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=32
REDIS_MIN_IDLE_CONNS=4
REDIS_DIAL_TIMEOUT_SECONDS=3
REDIS_READ_TIMEOUT_SECONDS=2
REDIS_WRITE_TIMEOUT_SECONDS=2
REDIS_POOL_TIMEOUT_SECONDS=3

# Local-only placeholders. Production release mode rejects weak or missing values.
JWT_SECRET=local_dev_jwt_secret_32_bytes_minimum_change_me
SRAPI_MASTER_KEY=local_dev_master_key_32_bytes_minimum_change_me
TOTP_ENCRYPTION_KEY=local_dev_totp_key_32_bytes_minimum_change_me
API_KEY_PEPPER=local_dev_api_key_pepper_change_me_32+

# The bootstrap admin is seeded ONLY when this email does not yet exist (first
# start). Changing BOOTSTRAP_ADMIN_PASSWORD afterwards has NO effect — the
# existing admin keeps its original password. To change it later, use the
# in-app password-reset flow, or point BOOTSTRAP_ADMIN_EMAIL at a fresh address.
BOOTSTRAP_ADMIN_EMAIL=admin@srapi.local
BOOTSTRAP_ADMIN_PASSWORD=password123
BOOTSTRAP_ADMIN_NAME=Admin

# Optional confidential-client console OAuth secrets, JSON keyed by provider_key.
# Secrets stay in deployment env (never AdminSettings); when a key is present the
# token exchange runs as a confidential client (client_secret_post) on top of PKCE.
OAUTH_CLIENT_SECRETS_JSON=
# Optional OIDC issuers, JSON keyed by provider_key. When set, the provider's
# id_token is verified at callback (signature via JWKS + iss/aud/exp + nonce).
OAUTH_ISSUERS_JSON=

# Optional Stripe test-mode payment smoke inputs.
STRIPE_SMOKE_SECRET_KEY=
STRIPE_SMOKE_WEBHOOK_SECRET=
STRIPE_SMOKE_AMOUNT=1.00
STRIPE_SMOKE_CURRENCY=USD
STRIPE_SMOKE_PROVIDER_NAME=stripe-smoke

# Optional Alipay Page Pay smoke inputs.
ALIPAY_SMOKE_APP_ID=
ALIPAY_SMOKE_PRIVATE_KEY=
ALIPAY_SMOKE_ALIPAY_PUBLIC_KEY=
ALIPAY_SMOKE_AMOUNT=1.00
ALIPAY_SMOKE_CURRENCY=CNY
ALIPAY_SMOKE_PROVIDER_NAME=alipay-smoke
ALIPAY_SMOKE_METHOD=alipay_smoke
ALIPAY_SMOKE_MODE=page
ALIPAY_SMOKE_GATEWAY_URL=
ALIPAY_SMOKE_NOTIFY_URL=
ALIPAY_SMOKE_RETURN_URL=
ALIPAY_SMOKE_LOCAL_WEBHOOK=0
ALIPAY_SMOKE_NOTIFY_PRIVATE_KEY=

# Optional WeChat Pay APIv3 smoke inputs.
WECHAT_SMOKE_APP_ID=
WECHAT_SMOKE_MCH_ID=
WECHAT_SMOKE_API_V3_KEY=
WECHAT_SMOKE_SERIAL_NO=
WECHAT_SMOKE_PRIVATE_KEY=
WECHAT_SMOKE_AMOUNT=1.00
WECHAT_SMOKE_CURRENCY=CNY
WECHAT_SMOKE_PROVIDER_NAME=wechat-smoke
WECHAT_SMOKE_METHOD=wechat_smoke
WECHAT_SMOKE_MODE=native
WECHAT_SMOKE_NOTIFY_URL=
WECHAT_SMOKE_DESCRIPTION=SRapi WeChat Pay smoke
WECHAT_SMOKE_PAYER_CLIENT_IP=
WECHAT_SMOKE_PAYER_OPENID=
WECHAT_SMOKE_H5_TYPE=
WECHAT_SMOKE_H5_APP_NAME=
WECHAT_SMOKE_H5_APP_URL=
WECHAT_SMOKE_H5_BUNDLE_ID=
WECHAT_SMOKE_H5_PACKAGE_NAME=
WECHAT_SMOKE_LOCAL_WEBHOOK=0
WECHAT_SMOKE_PLATFORM_PRIVATE_KEY=
WECHAT_SMOKE_PLATFORM_PUBLIC_KEY_ID=

GATEWAY_REQUEST_TIMEOUT_SECONDS=600
GATEWAY_STREAM_IDLE_TIMEOUT_SECONDS=120
GATEWAY_REALTIME_MAX_OPEN_SLOTS=0
GATEWAY_REALTIME_MAX_OPEN_SLOTS_PER_API_KEY=0
GATEWAY_MAX_BODY_SIZE=268435456
# Reject balance-billed requests (pay-go users, or allowance-mode subscription
# overage) synchronously when balance no longer covers the request, instead of
# relying on the deferred balance_charger worker. Never blocks hard_cap
# subscription users. Recommended true for paid production resale.
GATEWAY_REQUIRE_POSITIVE_BALANCE=false

GATEWAY_SCHEDULING_STICKY_SESSION_WAIT_TIMEOUT=120s
GATEWAY_SCHEDULING_FALLBACK_WAIT_TIMEOUT=30s

REVERSE_PROXY_HEADER_HYGIENE_STRICT=true
REVERSE_PROXY_COOKIE_JAR_ENCRYPTION_ENABLED=true

OPS_ENABLED=true

# Optional gateway request/response envelope dumps. Disabled by default; when
# enabled, files are stored under SRAPI_REQUEST_LOG_DIR and cleaned by age,
# error-file count, and total managed directory size. 0 = default 512 MiB,
# negative disables size-based eviction.
SRAPI_REQUEST_LOG_ENABLED=false
SRAPI_REQUEST_LOG_DIR=./logs/gateway
SRAPI_REQUEST_LOG_MAX_TOTAL_MB=512

DATA_RETENTION_USAGE_LOGS_DAYS=90
DATA_RETENTION_SCHEDULER_DECISIONS_DAYS=90
DATA_RETENTION_SCHEDULER_FEEDBACKS_DAYS=90
# scheduler_request_snapshots back the historical-replay tooling; one row per
# Scheduler attempt, so the table grows with raw QPS. 30 days bounds the
# strategy-replay window without inflating the on-disk budget.
DATA_RETENTION_SCHEDULER_REQUEST_SNAPSHOTS_DAYS=30
DATA_RETENTION_AUDIT_LOGS_DAYS=365
DATA_RETENTION_ACCOUNT_HEALTH_SNAPSHOTS_DAYS=90
DATA_RETENTION_BATCH_LIMIT=1000

BALANCE_CHARGER_INTERVAL_SECONDS=60
BALANCE_CHARGER_BATCH_LIMIT=500
BALANCE_CHARGER_MAX_BATCHES_PER_RUN=20

ACCOUNT_HEALTH_PROBE_INTERVAL_SECONDS=300
ACCOUNT_HEALTH_PROBE_TIMEOUT_SECONDS=10
ACCOUNT_HEALTH_PROBE_MAX_CONCURRENT=8
ACCOUNT_HEALTH_PROBE_FAILURE_THRESHOLD=3
ACCOUNT_HEALTH_PROBE_ERROR_RATE_THRESHOLD_PERCENT=50
ACCOUNT_HEALTH_PROBE_MIN_SAMPLES_FOR_ERROR_RATE=3
ACCOUNT_HEALTH_PROBE_COOLDOWN_SECONDS=300

SLO_EVALUATOR_INTERVAL_SECONDS=60
SLO_EVALUATOR_TIMEOUT_SECONDS=30
OPS_ALERT_NOTIFICATIONS_INTERVAL_SECONDS=30
OPS_ALERT_NOTIFICATIONS_TIMEOUT_SECONDS=30
OPS_ALERT_NOTIFICATIONS_BATCH_LIMIT=20

# Optional outbound transactional email for password reset and email verification.
# SMTP secrets are deployment env only and are not stored in AdminSettings.
# The same SMTP sender is reused by built-in Ops alert email channels.
EMAIL_PUBLIC_BASE_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_FROM=
EMAIL_SMTP_FROM_NAME=SRapi
EMAIL_SMTP_USE_TLS=false

# Optional human-verification (CAPTCHA) on login/register. Disabled by default.
# Provider: turnstile (default) | hcaptcha | recaptcha. Secret is deployment env only.
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=

# Optional scheduled per-account quota/subscription refresh. Disabled by default;
# only acts on accounts that expose a configured quota endpoint.
ACCOUNT_QUOTA_REFRESH_ENABLED=false
ACCOUNT_QUOTA_REFRESH_INTERVAL_SECONDS=1800
ACCOUNT_QUOTA_REFRESH_TIMEOUT_SECONDS=15
ACCOUNT_QUOTA_REFRESH_MAX_CONCURRENT=4

# Proactive OAuth access-token refresh worker. Only acts on oauth_refresh /
# oauth_device_code accounts whose token_expires_at falls inside the threshold
# window. Enabled by default — silently letting tokens expire is the failure
# mode this worker exists to prevent.
ACCOUNTS_TOKEN_REFRESH_ENABLED=true
ACCOUNTS_TOKEN_REFRESH_INTERVAL_SECONDS=300
ACCOUNTS_TOKEN_REFRESH_THRESHOLD_SECONDS=300
ACCOUNTS_TOKEN_REFRESH_TIMEOUT_SECONDS=30
ACCOUNTS_TOKEN_REFRESH_MAX_CONCURRENT=4

# Periodic outbound probe over each active proxy to the configured probe URL.
# Folds (success, failure, latency) into the proxy's rolling counters so the
# admin Availability column reflects a trailing window without a separate
# snapshot table. Disabled by default — turning this on starts making real
# outbound HTTPS calls from your box, which unattended deployments should
# opt into explicitly.
PROXY_PROBE_ENABLED=false
PROXY_PROBE_INTERVAL_SECONDS=21600
PROXY_PROBE_TIMEOUT_SECONDS=8
PROXY_PROBE_MAX_CONCURRENT=4
PROXY_PROBE_URL=https://www.cloudflare.com/cdn-cgi/trace

# Optional scheduled connectivity test. Issues a real (billable) generative probe
# to accounts that configure a probe model (test_model in account metadata) — for
# OAuth/non-api_key accounts the cheap health probe cannot cover. Disabled by default.
ACCOUNT_CONNECTIVITY_TEST_ENABLED=false
ACCOUNT_CONNECTIVITY_TEST_INTERVAL_SECONDS=3600
ACCOUNT_CONNECTIVITY_TEST_TIMEOUT_SECONDS=30
ACCOUNT_CONNECTIVITY_TEST_MAX_CONCURRENT=2

QUALITY_EVAL_ENABLED=false
QUALITY_EVAL_INTERVAL_SECONDS=3600
QUALITY_EVAL_TIMEOUT_SECONDS=30
QUALITY_EVAL_BATCH_LIMIT=100
QUALITY_EVAL_SAMPLE_PERCENT=1
QUALITY_EVAL_JUDGE_MODEL=gpt-4o-mini
QUALITY_EVAL_JUDGE_TIMEOUT_SECONDS=20
QUALITY_EVAL_OPENAI_BASE_URL=https://api.openai.com/v1
QUALITY_EVAL_OPENAI_API_KEY=
